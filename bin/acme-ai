#!/bin/rc
# acme-ai — Lux + Ollama integration for 9front acme
# Usage: acme-ai action
# winid is exported by acme in the environment.

lib=$home/lib/acme-ai
acmeroot=/mnt/acme

fn initacme {
	# Do not assign winid= at top level; that clears acme's exported winid.
	if (~ $#* 1) {
		if not (~ $1 '$winid') {
			if not (~ $1 '') {
				winid=$1
			}
		}
	}
	if (~ $#winid 0) {
		echo acme-ai: winid not set - run from acme >[1=2]
		exit nowinid
	}
	if (test -e /mnt/acme/$winid/rdsel) {
		acmeroot=/mnt/acme
		return
	}
	if (test -e /mnt/acme/acme/$winid/rdsel) {
		acmeroot=/mnt/acme/acme
		return
	}
	echo acme-ai: bad winid $winid >[1=2]
	exit badwin
}

fn acmefile {
	echo $acmeroot/$winid/$1
}

fn findlux {
	if (~ $objtype '') {
		objtype=`{echo $cputype}
	}
	if (test -x $home/bin/$objtype/lux) {
		echo $home/bin/$objtype/lux
		return
	}
	if (test -x $home/bin/lux) {
		echo $home/bin/lux
		return
	}
	if (test -x /acme/bin/$objtype/lux) {
		echo /acme/bin/$objtype/lux
		return
	}
	if (test -x /bin/lux) {
		echo /bin/lux
		return
	}
	echo 8.out
}

fn writerequest {
	action=$1
	rds=`{acmefile rdsel}
	addrf=`{acmefile addr}
	if (! test -d $lib) {
		echo acme-ai: missing $lib - run install.rc >[1=2]
		exit nolib
	}
	sel=`{cat $rds}
	if (~ $#sel 0) {
		echo acme-ai: no selection >[1=2]
		exit nsel
	}
	addr=`{cat $addrf}
	if (~ $#addr 0) {
		addr='(unknown)'
	}
	echo -n $action > $lib/request.action
	echo -n $addr > $lib/request.addr
	echo -n $sel > $lib/request.sel
}

fn runlux {
	script=$1
	luxbin=`{findlux}
	cd $lib
	resp=`{$luxbin $script}
	status=$status
	cd $home
	if (~ $status error) {
		echo '# acme-ai: lux failed ('^$status^')'
		return
	}
	if (~ $status compile) {
		echo '# acme-ai: lux failed ('^$status^')'
		return
	}
	if (~ $status runtime) {
		echo '# acme-ai: lux failed ('^$status^')'
		return
	}
	if (~ $#resp 0) {
		echo '# acme-ai: empty response'
		return
	}
	echo -n $resp
}

fn insertresult {
	text=$1
	ctlf=`{acmefile ctl}
	wrself=`{acmefile wrsel}
	echo -n 'insert ' > $ctlf
	echo -n $text > $wrself
}

fn acme-ai {
	if (~ $#* 0) {
		echo usage: acme-ai action >[1=2]
		echo actions: analyze explain fix chat chat-send >[1=2]
		exit usage
	}
	action=$1
	initacme $2

	switch ($action) {
	case analyze explain fix
		writerequest $action
		resp=`{runlux dispatch.lux}
		insertresult $resp

	case chat
		rds=`{acmefile rdsel}
		addrf=`{acmefile addr}
		sel=`{cat $rds}
		addr=`{cat $addrf}
		if (~ $#addr 0) {
			addr='(unknown)'
		}
		if (! test -d $lib) {
			echo acme-ai: missing $lib >[1=2]
			exit nolib
		}
		echo -n $winid > $lib/chat.session
		echo -n $addr > $lib/request.addr
		echo -n $sel > $lib/chat.context
		echo '[]' > $lib/chat-^$winid^.json
		win acme-ai chat-ui $winid

	case chat-send
		if (! test -d $lib) {
			echo acme-ai: missing $lib >[1=2]
			exit nolib
		}
		rds=`{acmefile rdsel}
		bodyf=`{acmefile body}
		sel=`{cat $rds}
		if (~ $#sel 0) {
			sel=`{cat $bodyf}
		}
		if (~ $#sel 0) {
			echo acme-ai: nothing to send >[1=2]
			exit nomsg
		}
		echo -n $sel > $lib/chat.message
		resp=`{runlux chat.lux}
		insertresult $resp

	case chat-ui
		srcwin=$1
		echo 'Add to tag column 1, middle-click inside quotes:'
		echo ''
		echo 'Source window:' $srcwin
		echo '''aichat'''

	case *
		echo acme-ai: unknown action $action >[1=2]
		exit badaction
	}
}

acme-ai $*
