#!/bin/rc
# aichat-send - send selection/body text to chat (stdin/stdout, same as t+)

lib=$home/lib/acme-ai

if(! test -d $lib){
	echo acme-ai: missing $lib - run install.rc >[1=2]
	exit nolib
}

cat > $lib/chat.message
if(! test -s $lib/chat.message){
	echo acme-ai: no selection >[1=2]
	echo '# acme-ai: no selection'
	exit nsel
}

luxbin=$home/bin/$cputype/lux
if(! test -x $luxbin)
	luxbin=$home/bin/lux
if(! test -x $luxbin)
	luxbin=8.out

cd $lib
$luxbin chat.lux
