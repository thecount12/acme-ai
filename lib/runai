#!/bin/rc
# runai action — Ollama via Lux; +AI window in acme, stdout in pipe mode

action=$1
lib=$home/lib/acme-ai

if(~ $#action 0){
	echo usage: runai action >[1=2]
	exit usage
}

if(! test -d $lib){
	echo acme-ai: missing $lib - run install.rc >[1=2]
	echo '# acme-ai: missing '$lib
	exit nolib
}

cat > $lib/request.sel
if(! test -s $lib/request.sel){
	echo acme-ai: no selection >[1=2]
	echo '# acme-ai: no selection'
	exit nsel
}

addr='(unknown)'
if(test -e /mnt/acme/$winid/rdsel){
	if(test -e /mnt/acme/$winid/addr)
		addr=`{cat /mnt/acme/$winid/addr}
}
if(test -e /mnt/acme/acme/$winid/rdsel){
	if(test -e /mnt/acme/acme/$winid/addr)
		addr=`{cat /mnt/acme/acme/$winid/addr}
}
echo -n $addr > $lib/request.addr
echo -n $action > $lib/request.action

luxbin=$home/bin/$cputype/lux
if(! test -x $luxbin)
	luxbin=$home/bin/lux
if(! test -x $luxbin)
	luxbin=/bin/lux
if(! test -x $luxbin){
	echo '# acme-ai: lux not found' >[1=2]
	echo '# acme-ai: lux not found'
	exit nolux
}

cd $lib
$luxbin dispatch.lux > response.txt

if(test -e /mnt/acme/$winid/rdsel || test -e /mnt/acme/acme/$winid/rdsel){
	$lib/aishow $action >[1=2]
	cat request.sel
}
if not {
	cat response.txt
}
