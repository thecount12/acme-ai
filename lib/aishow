#!/bin/rc
# aishow action — open +AI window (aspell-style via /mnt/wsys)

action=$1
lib=$home/lib/acme-ai
addr=

switch($#*){
case 0
	echo aishow: missing action >[1=2]
	exit usage
}

if(test -s $lib/request.addr)
	addr=`{cat $lib/request.addr}

winname=+AI
switch($addr){
case */*
	winname=`{basename -d $addr}^/+AI
}

dir=/mnt/wsys
if(! test -f $dir/cons)
	dir=/mnt/term/$dir
id=`{cat $dir/new/ctl}
id=$id(1)
echo 'name '^$winname > $dir/$id/ctl
{
	echo -n $action': '
	if(test -s $lib/request.addr)
		cat $lib/request.addr
	if(! test -s $lib/request.addr)
		echo '(unknown)'
	echo
	echo
	if(test -s $lib/response.txt)
		cat $lib/response.txt
	if(! test -s $lib/response.txt)
		echo '# acme-ai: empty response'
} > $dir/$id/body
{
	echo noscroll
	echo clean
}> $dir/$id/ctl
