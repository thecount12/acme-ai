// Self-contained dispatch (no imports, no classes). Run from $home/lib/acme-ai.

var plan9Hint = "Context: this code is from 9front or Plan 9. Plan 9 C uses print(), exits(), and different conventions than ISO C. Do not suggest printf, return from main, or POSIX-only APIs unless the code clearly targets POSIX. Use literal < and > in code examples.\n\n";

var configRaw = readFile("config.json");
if (configRaw == nil) {
    print "# acme-ai: could not read config.json";
    exit();
}

var config = parseJSON(configRaw);
if (config == nil) {
    print "# acme-ai: bad config.json";
    exit();
}

var action = readFile("request.action");
var addr = readFile("request.addr");
var selection = readFile("request.sel");

if (action == nil) {
    print "# acme-ai: missing request.action";
    exit();
}
if (selection == nil) {
    print "# acme-ai: missing request.sel";
    exit();
}
if (addr == nil) {
    addr = "(unknown)";
}

var models = config.models;
if (models == nil) {
    print "# acme-ai: config missing models";
    exit();
}

var model = nil;
if (action == "analyze") {
    model = models.analyze;
}
if (action == "explain") {
    model = models.explain;
}
if (action == "fix") {
    model = models.fix;
}
if (action == "chat") {
    model = models.chat;
}

if (model == nil) {
    print "# acme-ai: unknown action or missing model: " + action;
    exit();
}

var numPredict = 600;
var limits = config.num_predict;
if (limits != nil) {
    if (action == "analyze") {
        if (limits.analyze != nil) {
            numPredict = limits.analyze;
        }
    }
    if (action == "explain") {
        if (limits.explain != nil) {
            numPredict = limits.explain;
        }
    }
    if (action == "fix") {
        if (limits.fix != nil) {
            numPredict = limits.fix;
        }
    }
    if (action == "chat") {
        if (limits.chat != nil) {
            numPredict = limits.chat;
        }
    }
}

var prompt = nil;
if (action == "analyze") {
    prompt = plan9Hint + "Analyze the following code from " + addr + ".\nExplain what it does, note bugs, and suggest improvements. Be concise.\n\n" + selection;
}
if (action == "explain") {
    prompt = plan9Hint + "Briefly explain the following code from " + addr + ".\n\n" + selection;
}
if (action == "fix") {
    prompt = plan9Hint + "Review the following code from " + addr + ".\nSuggest a minimal fix as a unified diff.\n\n" + selection;
}

if (prompt == nil) {
    print "# acme-ai: unknown action: " + action;
    exit();
}

var host = config.host;
var url = "http://" + host + ":11434/api/generate";
var np = toJSON(numPredict);
var body = "{\"model\":" + toJSON(model) + ",\"prompt\":" + toJSON(prompt) + ",\"stream\":false,\"options\":{\"num_predict\":" + np + "}}";

var resp = httpPost(url, body);
if (resp == nil) {
    print "# acme-ai: Ollama request failed";
    exit();
}

var parsed = parseJSON(resp);
if (parsed == nil) {
    print "# acme-ai: bad Ollama response";
    exit();
}

var answer = parsed.response;
if (answer == nil) {
    print "# acme-ai: empty Ollama response";
    exit();
}

print answer;
