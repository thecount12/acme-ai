// Self-contained dispatch (no imports, no classes). Run from $home/lib/acme-ai.

var configRaw = readFile("config.json");
if (configRaw == nil) {
    print "# acme-ai: could not read config.json";
    exit();
}

var config = parseJSON(configRaw);
if (config == nil) {
    print "# acme-ai: bad config.json";
    exit();
}

var action = readFile("request.action");
var addr = readFile("request.addr");
var selection = readFile("request.sel");

if (action == nil) {
    print "# acme-ai: missing request.action";
    exit();
}
if (selection == nil) {
    print "# acme-ai: missing request.sel";
    exit();
}
if (addr == nil) {
    addr = "(unknown)";
}

var models = config.models;
if (models == nil) {
    print "# acme-ai: config missing models";
    exit();
}

var model = nil;
if (action == "analyze") {
    model = models.analyze;
}
if (action == "explain") {
    model = models.explain;
}
if (action == "fix") {
    model = models.fix;
}
if (action == "chat") {
    model = models.chat;
}

if (model == nil) {
    print "# acme-ai: unknown action or missing model: " + action;
    exit();
}

var prompt = nil;
if (action == "analyze") {
    prompt = "Analyze the following code from " + addr + ".\nExplain what it does, note bugs, and suggest improvements.\n\n" + selection;
}
if (action == "explain") {
    prompt = "Briefly explain the following code from " + addr + ".\n\n" + selection;
}
if (action == "fix") {
    prompt = "Review the following code from " + addr + ".\nSuggest a minimal fix as a unified diff.\n\n" + selection;
}

if (prompt == nil) {
    print "# acme-ai: unknown action: " + action;
    exit();
}

var host = config.host;
var url = "http://" + host + ":11434/api/generate";
var body = "{\"model\":" + toJSON(model) + ",\"prompt\":" + toJSON(prompt) + ",\"stream\":false}";

var resp = httpPost(url, body);
if (resp == nil) {
    print "# acme-ai: Ollama request failed";
    exit();
}

var parsed = parseJSON(resp);
if (parsed == nil) {
    print "# acme-ai: bad Ollama response";
    exit();
}

var answer = parsed.response;
if (answer == nil) {
    print "# acme-ai: empty Ollama response";
    exit();
}

print answer;
